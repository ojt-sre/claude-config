{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(claude *)",
      "Bash(crontab *)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(rm /tmp/*)",
      "Bash(du *)",
      "Bash(readlink *)",
      "Bash(file *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(wc *)",
      "Bash(uniq *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(tee *)",
      "Bash(xargs *)",
      "Bash(bash -n *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cd *)",
      "Bash(for *)",
      "Bash(sleep *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(wget *)",
      "Bash(curl * | bash *)",
      "Bash(curl * | sh *)",
      "Bash(chmod 777 *)",
      "Bash(git push --force *)",
      "Bash(git config --global *)",
      "Bash(git config --system *)",
      "Bash(npm install -g *)",
      "Bash(npm i -g *)",
      "Bash(apt install *)",
      "Bash(apt-get install *)",
      "Bash(brew install *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.ssh/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)",
      "Write(~/.ssh/**)",
      "Write(**/*.pem)",
      "Write(**/*.key)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/validate-command.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-bash-failure.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-bash-approval.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-approve-edit-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-approve-bash.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stop-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py"
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest"
}
